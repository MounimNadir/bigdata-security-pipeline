{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["security", "ids"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Security IDS Dashboard",
  "uid": "security-pipeline",
  "version": 1,
  "weekStart": "",
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Total Alerts",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "options": {
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "rawSql": "SELECT COUNT(*) AS value FROM alerts WHERE $__timeFilter(timestamp)",
          "format": "table",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Critical Alerts",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "options": {
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "rawSql": "SELECT COUNT(*) AS value FROM alerts WHERE $__timeFilter(timestamp) AND severity = 'CRIT'",
          "format": "table",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Events Processed",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "options": {
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "rawSql": "SELECT SUM(event_count) AS value FROM traffic_stats WHERE $__timeFilter(window_start)",
          "format": "table",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Total Bytes Transferred",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "options": {
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "rawSql": "SELECT SUM(bytes_total) AS value FROM traffic_stats WHERE $__timeFilter(window_start)",
          "format": "table",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "type": "barchart",
      "title": "Alerts by Detection Rule",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "options": {
        "orientation": "auto",
        "xTickLabelRotation": 0,
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "fillOpacity": 80,
        "gradientMode": "none",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1,
            "axisPlacement": "auto",
            "axisCenteredZero": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "rawSql": "SELECT rule_triggered, COUNT(*) AS count FROM alerts GROUP BY rule_triggered ORDER BY count DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "type": "barchart",
      "title": "Alerts by Severity",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "options": {
        "orientation": "auto",
        "xTickLabelRotation": 0,
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "fillOpacity": 80,
        "gradientMode": "none",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1,
            "axisPlacement": "auto",
            "axisCenteredZero": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "MED" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "HIGH" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "CRIT" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "rawSql": "SELECT severity, COUNT(*) AS count FROM alerts GROUP BY severity ORDER BY CASE severity WHEN 'LOW' THEN 1 WHEN 'MED' THEN 2 WHEN 'HIGH' THEN 3 WHEN 'CRIT' THEN 4 END",
          "format": "table",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Events Over Time by Topic",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": false,
            "axisPlacement": "auto",
            "axisCenteredZero": false,
            "scaleDistribution": { "type": "linear" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "rawSql": "SELECT window_start AS \"time\", SUM(CASE WHEN topic = 'auth' THEN event_count ELSE 0 END) AS \"Auth\", SUM(CASE WHEN topic = 'firewall' THEN event_count ELSE 0 END) AS \"Firewall\", SUM(CASE WHEN topic = 'web' THEN event_count ELSE 0 END) AS \"Web\" FROM traffic_stats WHERE $__timeFilter(window_start) GROUP BY window_start ORDER BY window_start",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Bytes Transferred Over Time",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": false,
            "axisPlacement": "auto",
            "axisCenteredZero": false,
            "scaleDistribution": { "type": "linear" }
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "rawSql": "SELECT window_start AS \"time\", SUM(CASE WHEN topic = 'firewall' THEN bytes_total ELSE 0 END) AS \"Firewall\", SUM(CASE WHEN topic = 'web' THEN bytes_total ELSE 0 END) AS \"Web\" FROM traffic_stats WHERE $__timeFilter(window_start) GROUP BY window_start ORDER BY window_start",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },

    {
      "id": 9,
      "type": "table",
      "title": "Recent Alerts",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 10 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false, "reducer": ["sum"], "countRows": false, "fields": "" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto", "inspect": false }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "severity" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "LOW":  { "color": "blue",   "index": 0, "text": "LOW"  },
                      "MED":  { "color": "yellow",  "index": 1, "text": "MED"  },
                      "HIGH": { "color": "orange",  "index": 2, "text": "HIGH" },
                      "CRIT": { "color": "red",     "index": 3, "text": "CRIT" }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "rule_triggered" },
            "properties": [
              { "id": "custom.width", "value": 180 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "timestamp" },
            "properties": [
              { "id": "custom.width", "value": 180 }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "rawSql": "SELECT timestamp, source_ip, country, destination_ip, rule_triggered, severity FROM alerts ORDER BY timestamp DESC LIMIT 50",
          "format": "table",
          "refId": "A"
        }
      ]
    }

  ]
}
