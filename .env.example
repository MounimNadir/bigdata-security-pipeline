# ======================
# PostgreSQL
# ======================
POSTGRES_USER=secadmin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=securitydb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ======================
# Kafka
# ======================
KAFKA_BROKER=kafka:9092
KAFKA_TOPIC_AUTH=auth-logs
KAFKA_TOPIC_FIREWALL=firewall-logs
KAFKA_TOPIC_WEB=web-logs
KAFKA_RETENTION_MS=604800000

# ======================
# Producer
# ======================
PRODUCER_RATE_AUTH=5
PRODUCER_RATE_FIREWALL=15
PRODUCER_RATE_WEB=10
# Attack injection interval in seconds (use 5-10 for testing, 30-60 for demo)
ATTACK_INTERVAL_MIN=30
ATTACK_INTERVAL_MAX=60

# ======================
# Spark
# ======================
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g
# Micro-batch trigger interval in SECONDS (how often Spark wakes up)
SPARK_BATCH_INTERVAL=10
SPARK_KAFKA_PACKAGE=org.apache.spark:spark-sql-kafka-0-10_2.12:3.5.0
PARQUET_OUTPUT_PATH=/app/data/parquet

# ======================
# GeoIP
# ======================
GEOIP_DB_PATH=/app/data/GeoLite2-Country.mmdb

# ======================
# Grafana
# ======================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
